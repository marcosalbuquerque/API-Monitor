# ============================================================================
# API Monitor - variaveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
#   cp .env.example .env
# ============================================================================

# -- Servidor ----------------------------------------------------------------

PORT=3001

# -- Dynatrace / OpenTelemetry -----------------------------------------------
#
# Como obter as credenciais
#
#   1 Acesse seu ambiente Dynatrace
#      https://{environment-id}.live.dynatrace.com
#
#   2 Va em
#      Settings -> Integrations -> OpenTelemetry
#      ou busque "OpenTelemetry" na barra de pesquisa
#
#   3 Anote o Environment ID
#      aparece na URL ex abc12345
#
#   4 Gere um Access Token
#      Settings -> Access Tokens -> Generate new token
#
#      Escopos obrigatorios
#        openTelemetryTrace.ingest
#        metrics.ingest
#
#   5 Cole os valores abaixo

# Endpoint OTLP HTTP do seu ambiente Dynatrace
# Formato
# https://{environment-id}.live.dynatrace.com/api/v2/otlp/v1/traces

DYNATRACE_OTLP_ENDPOINT=https://{seu-environment-id}.live.dynatrace.com/api/v2/otlp/v1/traces

# Token gerado no passo 4
# Normalmente comeca com dt0c01

DYNATRACE_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Nome do servico exibido no Dynatrace
# Aparece em Services -> api-monitor-backend

OTEL_SERVICE_NAME=api-monitor-backend

# -- Observacoes --------------------------------------------------------------
#
# Se DYNATRACE_OTLP_ENDPOINT ou DYNATRACE_API_TOKEN nao estiverem
# preenchidos o backend sobe normalmente sem telemetria
# Seguro para desenvolvimento local
#
# Para Dynatrace Managed on-premise o endpoint muda para
# https://{seu-dominio}/e/{environment-id}/api/v2/otlp/v1/traces
#
# Os traces aparecem no Dynatrace em
# Distributed Traces -> Ingested Traces
#
# A primeira ingestao pode levar ate 2 minutos
