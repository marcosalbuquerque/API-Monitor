# Variáveis de ambiente do backend
# Copie este arquivo para .env e preencha com seus valores

PORT=3001

# ─── Dynatrace (OpenTelemetry) ───────────────────────────────────────────────
# Só necessário se usar a integração OpenTelemetry (Opção B)
# Deixe vazio se usar o OneAgent (Opção A)

DYNATRACE_OTLP_ENDPOINT=https://{seu-environment-id}.live.dynatrace.com/api/v2/otlp/v1/traces
DYNATRACE_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXXXXXX
