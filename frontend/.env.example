# ============================================================================
# API Monitor Frontend - variaveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
#   cp .env.example .env
#
# IMPORTANTE - seguranca
#
# Todas as variaveis com prefixo VITE_ ficam visiveis no bundle final
# codigo JavaScript do browser
#
# Por isso
#   Use um token com escopos minimos
#   Apenas ingest de traces
#
#   Nunca use tokens de admin aqui
#
#   Para producao use um token separado do backend
# ============================================================================

# -- Dynatrace / OpenTelemetry -----------------------------------------------
#
# Como obter as credenciais
#
#   1 Acesse seu ambiente Dynatrace
#      https://{environment-id}.live.dynatrace.com
#
#   2 Gere um Access Token
#      Settings -> Access Tokens -> Generate new token
#
#      Escopo obrigatorio
#        openTelemetryTrace.ingest
#
#   3 Endpoint OTLP para browser
#      Mesmo do backend
#
#      https://{environment-id}.live.dynatrace.com/api/v2/otlp/v1/traces
#
#   IMPORTANTE
#   O Dynatrace SaaS aceita requisicoes OTLP direto do browser
#
#   Se usar Dynatrace Managed on-premise
#   verifique se o CORS esta habilitado no ambiente

# Endpoint OTLP HTTP do seu ambiente Dynatrace

VITE_DYNATRACE_OTLP_ENDPOINT=https://{seu-environment-id}.live.dynatrace.com/api/v2/otlp/v1/traces

# Token de ingest
# Apenas escopo openTelemetryTrace.ingest

VITE_DYNATRACE_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Nome do servico exibido no Dynatrace

VITE_OTEL_SERVICE_NAME=api-monitor-frontend

# Versao da aplicacao
# Opcional

VITE_APP_VERSION=1.0.0

# -- Observacoes --------------------------------------------------------------
#
# Se as variaveis nao estiverem preenchidas
# o frontend funciona normalmente sem enviar traces
#
# Seguro para desenvolvimento local
#
# Os traces do frontend e backend aparecem juntos no Dynatrace
# quando o W3C TraceContext e propagado
#
# Headers utilizados
#   traceparent
#   tracestate
#
# A FetchInstrumentation injeta esses headers automaticamente
# nas chamadas ao backend
#
# O backend tambem precisa estar instrumentado
#
# Para visualizar os traces
# Dynatrace -> Distributed Traces -> Ingested Traces
#
# Filtre por
# service.name = "api-monitor-frontend"
